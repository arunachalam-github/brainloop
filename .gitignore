app/src-tauri/resources/

# macOS
.DS_Store
.AppleDouble
._*
.Spotlight-V100
.Trashes

# brainloop runtime artifacts — user-specific, never commit
com.brainloop.agent.plist
*.db
*.log

# Day reports — personal data, user-specific
apps/brainloop_april*.html
apps/brainloop_[0-9]*.html
apps/brain_fog.html

# Design explorations — local scratch files
apps/timed_oval_design.html
apps/timed_oval_design_yesterday.html
apps/design_explorations.html
apps/brainloop_switches.html

# IDE
.vscode/
.idea/
*.swp
*.swo

# Environment
.env

# Git worktrees (local isolation; never commit)
.worktrees/
